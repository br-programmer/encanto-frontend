# =============================================================================
# ENCANTO FRONTEND - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and replace placeholder values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Site URL (used for sitemap, SEO metadata)
NEXT_PUBLIC_SITE_URL=https://encanto.com.ec

# CDN hostname for Next.js Image optimization (remote patterns)
NEXT_PUBLIC_CDN_HOSTNAME=dev-cdn.encanto.com.ec

# PayPal Client ID (sandbox or live)
# Get from https://developer.paypal.com/dashboard/applications
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# SEO Indexing
# Set to "true" to allow search engines to index the site
# Leave empty or omit in non-production environments
NEXT_PUBLIC_INDEXABLE=

# Sitemap API Key (shared with backend, server-side only)
# Must match SITEMAP_API_KEY in the backend .env
# Generate with: openssl rand -hex 32
SITEMAP_API_KEY=
